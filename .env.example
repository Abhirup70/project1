# Configuration file for Currency Converter API
# Copy this to .env and modify as needed

# API Settings
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Exchange Rate API
# Get your free API key from https://exchangerate-api.com/
EXCHANGE_API_KEY=
EXCHANGE_API_BASE_URL=https://api.exchangerate-api.com/v4

# Cache Settings
CACHE_TTL=3600  # Cache expiry time in seconds (1 hour)

# CORS Settings
CORS_ORIGINS=*

# Server Settings
WORKERS=4
RELOAD=False
